// 8 Claude agents - 4 columns on top, 4 on the bottom. Shortcut strip at the bottom.
layout {
    default_tab_template {
        pane size=1 borderless=true { plugin location="zellij:tab-bar"; }
        pane size=1 borderless=true command="node" { args "{{APP}}/separator.mjs"; }
        children
    }
    tab {
        pane split_direction="horizontal" {
                pane split_direction="horizontal" {
                    pane split_direction="vertical" { pane command="claude" name="Claude 1"; pane command="claude" name="Claude 2"; pane command="claude" name="Claude 3"; pane command="claude" name="Claude 4"; }
                    pane split_direction="vertical" { pane command="claude" name="Claude 5"; pane command="claude" name="Claude 6"; pane command="claude" name="Claude 7"; pane command="claude" name="Claude 8"; }
                }
                pane size=1 borderless=true command="node" { args "{{APP}}/agentbar.mjs"; }
        }
    }
}
