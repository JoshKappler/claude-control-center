// 3 Claude agents - 3 narrow vertical columns.
layout {
    default_tab_template {
        pane size=1 borderless=true { plugin location="zellij:tab-bar"; }
        children
    }
    tab {
        pane split_direction="horizontal" {
            pane size=1 borderless=true command="node" {
                args "{{APP}}/agentbar.mjs"
            }
            pane split_direction="vertical" {
                pane command="claude" name="Claude 1"
                pane command="claude" name="Claude 2"
                pane command="claude" name="Claude 3"
            }
        }
    }
}
