// 5 Claude agents - column-heavy: 3 columns on top, 2 on the bottom.
layout {
    default_tab_template {
        pane size=1 borderless=true { plugin location="zellij:tab-bar"; }
        children
    }
    tab {
        pane split_direction="horizontal" {
            pane size=1 borderless=true command="node" {
                args "{{APP}}/agentbar.mjs"
            }
            pane split_direction="horizontal" {
                pane split_direction="vertical" { pane command="claude" name="Claude 1"; pane command="claude" name="Claude 2"; pane command="claude" name="Claude 3"; }
                pane split_direction="vertical" { pane command="claude" name="Claude 4"; pane command="claude" name="Claude 5"; }
            }
        }
    }
}
