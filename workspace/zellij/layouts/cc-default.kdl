// cc-default — the control-center session layout (Tab 0 = Home, the Node TUI).
// Deployed by `node install.mjs`; script paths are rewritten to this repo's path.
// `default_layout "cc-default"` resolves it by name; the launcher creates the
// session via `zellij attach -c claude-cc`.
//
// NO tab-bar on Home: the built-in zellij tab-bar plugin hard-codes the session
// name ("Zellij (claude-cc)") and the swap-layout name ("BASE") with no option to
// hide them, and a custom status plugin (zjstatus) would break the zero-dep rule.
// Home doesn't need a tab strip anyway — you ARE home; the dashboard names itself.
// Switch to your agent windows with Alt+] / Alt+H. Agent tabs keep their tab strip
// (seeing the open windows there is useful) — see home.mjs genLayout().
layout {
    tab name="Home" focus=true {
        // borderless: keep the dashboard frameless even though pane_frames is on
        // (frames are for the agent tabs, to show which Claude is focused).
        pane borderless=true command="node" {
            args "{{APP}}/home.mjs"
        }
    }
}
