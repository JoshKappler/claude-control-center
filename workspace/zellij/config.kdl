// ~/.config/zellij/config.kdl  — deployed by `node install.mjs` from this repo.
// Script paths below are rewritten to this repo's absolute location at install time.
theme "homebrew"
// Pane frames ON: each agent gets a thin titled border ("Claude 1", "Claude 2",
// ...) and the FOCUSED agent's border is highlighted, so you always see which
// instance your keystrokes go to. Home and the hint/tab bars stay borderless.
pane_frames true
// Mouse ON: the pointer must work (click to focus a pane, click the Home tab to
// jump back, drag a border to resize). Turning it off had stranded the cursor as
// a text selector. The confusing "ALT-click group" hint is avoided by using the
// plain tab-bar (not the compact/status bar) for the top row instead.
mouse_mode true
default_layout "cc-default"   // the control center's Home tab; `zellij attach -c claude-cc` creates the session with this
show_startup_tips false
copy_on_select true
// macOS: copy selections straight to the system clipboard via pbcopy — OSC52 doesn't
// reliably reach the Mac clipboard through WezTerm. On Windows pbcopy doesn't exist,
// so install.mjs renders this token to the pbcopy line on macOS and to nothing on
// Windows (where the OSC52 default works fine in WezTerm).
{{COPY_COMMAND}}
// SESSION DURABILITY — the 2026-07-01 incident rule: no keystroke, client crash, or
// window close may ever irrecoverably kill a session with agents in it. Closing the
// window only DETACHES; the session (and every agent) keeps running, and the next
// launch reattaches to it. Ending a session is always deliberate: close its tabs
// (Ctrl+Alt+Q) or run `zellij delete-session claude-cc --force`.
on_force_close "detach"
// Persist sessions to disk too, so even a zellij-server crash or reboot leaves a
// resurrectable snapshot instead of four lost hours.
session_serialization true

// Green-on-black phosphor theme to match WezTerm's Homebrew scheme — in zellij's
// component format (0.42+), NOT the old fg/bg palette. The old format painted
// inactive tab ribbons with `fg` and the active one with `green`, and this theme
// needs both to be phosphor green — so every tab looked identical and you could
// not tell which tab you were in. With components the ACTIVE tab is the single
// solid bright-green block (black text) while inactive tabs are dim green text on
// plain black. Frames get the same split: the focused agent's border is bright,
// unfocused ones dim.
themes {
    homebrew {
        text_unselected {
            base 51 255 51
            background 0 0 0
            emphasis_0 136 255 0
            emphasis_1 0 255 204
            emphasis_2 51 255 51
            emphasis_3 51 255 170
        }
        text_selected {
            base 0 0 0
            background 51 255 51
            emphasis_0 136 255 0
            emphasis_1 0 204 102
            emphasis_2 0 100 0
            emphasis_3 0 153 0
        }
        // INACTIVE tabs: dim green text, no block — they melt into the bar.
        ribbon_unselected {
            base 30 150 30
            background 0 0 0
            emphasis_0 0 204 0
            emphasis_1 204 255 204
            emphasis_2 0 204 102
            emphasis_3 51 255 170
        }
        // ACTIVE tab: the one solid bright-green block on the bar.
        ribbon_selected {
            base 0 0 0
            background 51 255 51
            emphasis_0 0 204 0
            emphasis_1 0 100 0
            emphasis_2 0 153 0
            emphasis_3 0 204 102
        }
        table_title {
            base 170 255 0
            background 0 0 0
            emphasis_0 136 255 0
            emphasis_1 0 255 204
            emphasis_2 51 255 51
            emphasis_3 51 255 170
        }
        table_cell_unselected {
            base 51 255 51
            background 0 0 0
            emphasis_0 136 255 0
            emphasis_1 0 255 204
            emphasis_2 0 204 102
            emphasis_3 51 255 170
        }
        table_cell_selected {
            base 0 0 0
            background 51 255 51
            emphasis_0 136 255 0
            emphasis_1 0 100 0
            emphasis_2 0 153 0
            emphasis_3 0 204 102
        }
        list_unselected {
            base 51 255 51
            background 0 0 0
            emphasis_0 136 255 0
            emphasis_1 0 255 204
            emphasis_2 0 204 102
            emphasis_3 51 255 170
        }
        list_selected {
            base 0 0 0
            background 51 255 51
            emphasis_0 136 255 0
            emphasis_1 0 100 0
            emphasis_2 0 153 0
            emphasis_3 0 204 102
        }
        // Unfocused agent borders: dim. The focused agent's border: bright.
        frame_unselected {
            base 30 150 30
            background 0 0 0
            emphasis_0 136 255 0
            emphasis_1 0 255 204
            emphasis_2 0 204 102
            emphasis_3 51 255 170
        }
        frame_selected {
            base 51 255 51
            background 0 0 0
            emphasis_0 170 255 0
            emphasis_1 0 255 204
            emphasis_2 51 255 170
            emphasis_3 0 204 102
        }
        frame_highlight {
            base 170 255 0
            background 0 0 0
            emphasis_0 136 255 0
            emphasis_1 170 255 0
            emphasis_2 170 255 0
            emphasis_3 170 255 0
        }
        exit_code_success {
            base 51 255 51
            background 0 0 0
            emphasis_0 0 255 204
            emphasis_1 0 204 102
            emphasis_2 51 255 170
            emphasis_3 204 255 204
        }
        // The EXITED banner ("press Enter to re-run" = resume the conversation)
        // renders in this — phosphor yellow so a dead agent is spottable.
        exit_code_error {
            base 170 255 0
            background 0 0 0
            emphasis_0 136 255 0
            emphasis_1 0 204 0
            emphasis_2 0 204 102
            emphasis_3 51 255 170
        }
        multiplayer_user_colors {
            player_1 0 255 204
            player_2 170 255 0
            player_3 51 255 170
            player_4 204 255 204
            player_5 0 204 102
            player_6 136 255 0
            player_7 0 204 0
            player_8 51 255 51
            player_9 30 150 30
            player_10 0 153 0
        }
    }
}

keybinds {
    // Ctrl+g toggles LOCKED mode, which passes every key straight to Claude so
    // Zellij never eats its shortcuts. The hint bar shows how to leave locked mode.
    normal {
        bind "Ctrl g" { SwitchToMode "locked"; }
    }
    locked {
        bind "Ctrl g" { SwitchToMode "normal"; }
    }

    // --- Control Center actions (active in every mode except locked) ---
    shared_except "locked" {
        // Alt+s: reveal EVERY shortcut for the current page in a BIG floating overlay
        // (~90% of the screen — so the two-column table never wraps and never needs
        // scrolling; the old default-sized pane was the tiny window that mangled it).
        // It TOGGLES — press Alt+s again (or any other key) to close it. cheatsheet.mjs
        // drops a marker file so a second press collapses the open overlay instead of
        // stacking another on top. `close_on_exit true` is the RELIABLE close: when the
        // script exits (a key, or the toggle removing the marker) Zellij tears the pane
        // down itself — no dependence on `zellij action close-pane` reaching a focused
        // pane, which is why the overlay kept getting stuck open. This is THE discovery
        // key — the thin bar under the tab strip advertises it on every tab.
        bind "Alt s" { Run "node" "{{APP}}/cheatsheet.mjs" { floating true; name "shortcuts"; close_on_exit true; x "5%"; y "5%"; width "90%"; height "90%"; }; }
        // Alt+a: add another Claude agent in this tab. Runs agent-pane.mjs (not bare
        // `claude`) so the pane resumes ITS OWN conversation on any re-run — claude
        // exiting (crash, /exit, auto-update) or a resurrected session no longer
        // silently starts a fresh chat. `--key auto` derives a stable key from the
        // zellij session + pane id (a static keybind can't mint a per-launch nonce).
        bind "Alt a" { Run "node" "{{APP}}/agent-pane.mjs" "--key" "auto" "--" "--dangerously-skip-permissions"; }
        // Alt+h: jump straight back to the Home dashboard (always the first tab).
        bind "Alt h" { GoToTab 1; }
        // Alt+Shift+Arrows: resize the focused agent (grow toward that edge). Pairs
        // with Alt+Arrows (move focus) — same fingers, add Shift to resize.
        bind "Alt Shift Left"  { Resize "Increase Left"; }
        bind "Alt Shift Right" { Resize "Increase Right"; }
        bind "Alt Shift Up"    { Resize "Increase Up"; }
        bind "Alt Shift Down"  { Resize "Increase Down"; }
        // Alt+i: open the subagent monitor for this window as a floating overlay.
        bind "Alt i" { Run "node" "{{APP}}/inspector.mjs" { floating true; }; }
        // Ctrl+Alt+w: DELIBERATE manual close of the focused agent. Closing is the
        // only way an agent dies — casual tab/pane navigation never can (see below).
        bind "Ctrl Alt w" { CloseFocus; }
        // Switch between agent windows (tabs). Repurpose Alt+[ / Alt+] — zellij's
        // default swap-layout keys, which we don't use — into prev/next tab, so
        // the brackets you used to see now actually move between windows.
        bind "Alt [" { GoToPreviousTab; }
        bind "Alt ]" { GoToNextTab; }
        // Alt+Arrows: move focus between the Claude agents INSIDE this tab. The
        // highlighted border shows which one is active; stays within the tab.
        bind "Alt Left"  { MoveFocus "Left"; }
        bind "Alt Right" { MoveFocus "Right"; }
        bind "Alt Up"    { MoveFocus "Up"; }
        bind "Alt Down"  { MoveFocus "Down"; }
        // Ctrl+Alt+q: deliberately close this WHOLE tab (all of its agents at
        // once). Ctrl+Alt+w above closes only the single focused agent.
        bind "Ctrl Alt q" { CloseTab; }
        // Keyboard scrollback for the chat, matching the mouse wheel (which stays
        // the primary way to scroll). While scrolled, zellij shows the position as
        // "SCROLL: <line>/<total>" on the pane's top border — that indicator is the
        // closest thing to a scrollbar zellij can render (it has no graphical bar,
        // and its plugin API exposes no scroll offset to draw one from). Alt-based
        // so nothing is stolen from Claude; Alt+End snaps back to the live tail.
        bind "Alt PageUp"   { PageScrollUp; }
        bind "Alt PageDown" { PageScrollDown; }
        bind "Alt End"      { ScrollToBottom; }
        // No-kill guard: disable global Quit so one keystroke can't nuke every agent.
        unbind "Ctrl q"
        // Stop Zellij from eating ordinary terminal/Claude keys and popping up mode
        // overlays. Ctrl+Backspace (delete word) emits Ctrl+H, which by DEFAULT
        // opens Zellij's Move mode — that was the unexplained overlay. Unbind it and
        // the other default mode-entry keys we don't use, so they pass straight
        // through to Claude. Only `normal` and `locked` modes remain reachable; the
        // intentional Alt+ workflow and Ctrl+g lock are untouched. Mouse scroll
        // still covers scrollback, so dropping Ctrl+s scroll mode is fine.
        unbind "Ctrl h"
        unbind "Ctrl p"
        unbind "Ctrl n"
        unbind "Ctrl t"
        unbind "Ctrl s"
        unbind "Ctrl o"
        unbind "Ctrl b"
    }

    // No-kill guard: strip the casual close-pane / close-tab keys from every mode
    // that bound them by default, so switching/adding/backtracking can't kill agents.
    pane {
        unbind "x"
    }
    tab {
        unbind "x"
    }
    tmux {
        unbind "x"
    }
}
